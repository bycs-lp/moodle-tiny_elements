{{!
    @template tiny_elements/modal

    Modal to manage components within the Tiny Editor.

    Three-axis layout: category rail (left), flavor chips + variant strip + component grid (main),
    preview pane with explicit insert button (right). All interactivity is wired by amd/src/ui.js.

    Example context (json):
    {
    "elementid": "elements-plugin-container",
    "preview": true,
    "canmanage": true,
    "buttons": [
        {
        "id": 1,
        "name": "Tip",
        "type": "teachpals",
        "imageClass": "elements-teachpals-tip-icon",
        "htmlcode": "<div></div>",
        "variants": [
            {
            "id": 8,
            "displayname": "Avatar 2",
            "name": "avatar2",
            "state": "off",
            "imageClass": "avatar2-variant-off",
            "variantclass": "elements-avatar2-variant",
            "title": "Avatar 2"
            }
        ],
        "flavorlist": "robi-bot,horst-cloud",
        "category": "teachpals"
        }
    ],
    "categories": [
        {
        "categoryid": 4,
        "name": "Teach Pals",
        "categoryname": "teachpals",
        "type": 4,
        "displayorder": 1,
        "componentcount": 2,
        "initial": "T",
        "flavors": [
            {"id": 1, "name": "horst-cloud", "displayname": "Horst und Wölkchen"},
            {"id": 12, "name": "robi-bot", "displayname": "Robi und Bot"}
        ],
        "hasFlavors": 2,
        "active": "active"
        }
    ]
    }
}}
{{< core/modal }}
    {{$header}}
        <h5 id="{{uniqid}}-modal-title" class="modal-title" data-region="title">{{#str}} pluginname, tiny_elements {{/str}}</h5>
        {{#canmanage}}
        <a href="{{global.config.wwwroot}}/lib/editor/tiny/plugins/elements/management.php" class="btn btn-sm" target="_blank">
            {{#pix}} i/settings, core, {{#str}} manage, tiny_elements {{/str}}{{/pix}}
        </a>
        {{/canmanage}}
    {{/header}}
    {{$body}}
        <div id="{{elementid}}" class="elements-plugin-container elements-modal-grid {{^preview}}elements-no-preview{{/preview}}">
            <aside class="elements-rail" aria-label="{{#str}} category, tiny_elements {{/str}}">
                <div class="elements-rail-list" role="tablist">
                    {{#categories}}
                        <div class="elements-rail-group" data-categoryid="{{categoryid}}">
                            <button type="button"
                                    class="elements-rail-item {{active}}"
                                    role="tab"
                                    aria-selected="{{#active}}true{{/active}}{{^active}}false{{/active}}"
                                    data-categoryid="{{categoryid}}"
                                    data-categoryname="{{categoryname}}"
                                    data-hasflavors="{{hasFlavors}}">
                                <span class="elements-rail-meta">
                                    <span class="elements-rail-name">{{name}}</span>
                                    <span class="elements-rail-count">{{#str}} componentcount, tiny_elements, {{componentcount}} {{/str}}</span>
                                </span>
                            </button>
                            {{#hasFlavors}}
                                <div class="elements-flavor-list"
                                     data-categoryid="{{categoryid}}"
                                     data-categoryname="{{categoryname}}"
                                     {{^active}}hidden{{/active}}>
                                    <button type="button"
                                            class="elements-flavor-chip elements-flavor-none active"
                                            data-categoryid="{{categoryid}}"
                                            data-categoryname="{{categoryname}}"
                                            data-flavor=""
                                            aria-controls="elements-buttons-grid">
                                        {{#str}} noflavor, tiny_elements {{/str}}
                                    </button>
                                    {{#flavors}}
                                        <button type="button"
                                                class="elements-flavor-chip elements-category-flavor"
                                                data-id="{{id}}"
                                                data-categoryid="{{categoryid}}"
                                                data-categoryname="{{categoryname}}"
                                                data-flavor="{{name}}"
                                                aria-controls="elements-buttons-grid">
                                            {{displayname}}
                                        </button>
                                    {{/flavors}}
                                </div>
                            {{/hasFlavors}}
                        </div>
                    {{/categories}}
                </div>
            </aside>

            <div class="elements-main">
                <div class="elements-grid-wrap">
                    <div id="elements-buttons-grid" class="elements-buttons-grid" role="listbox" aria-label="{{#str}} pluginname, tiny_elements {{/str}}">
                        {{#buttons}}
                            <button type="button"
                                    class="elementst-dialog-button"
                                    role="option"
                                    aria-selected="false"
                                    data-id="{{id}}"
                                    data-type="{{type}}"
                                    data-classcomponent="{{imageClass}}"
                                    data-flavorlist="{{flavorlist}}"
                                    data-category="{{category}}">
                                <span class="elements-v-dots">
                                    {{#variants}}
                                        <span class="elements-v-dot {{state}}"
                                              data-variant="{{name}}"
                                              data-variantclass="{{variantclass}}"
                                              title="{{displayname}}"
                                              aria-label="{{displayname}}"></span>
                                    {{/variants}}
                                </span>
                                <span class="elements-comp-icon {{imageClass}}" aria-hidden="true">
                                    {{#icon}}<i class="icon" style="background-image: url({{icon}});"></i>{{/icon}}
                                </span>
                                <span class="elements-comp-name">{{{name}}}</span>
                            </button>
                        {{/buttons}}
                    </div>
                </div>

                <div class="elements-variant-strip" data-region="variant-strip" hidden>
                    <span class="elements-bar-label">{{#str}} variant, tiny_elements {{/str}}</span>
                    <span class="elements-variant-target" data-region="variant-target"></span>
                    <div class="elements-variant-chips" data-region="variant-chips"></div>
                </div>
            </div>

            {{#preview}}
            <aside class="elements-preview" data-region="preview" aria-label="{{#str}} preview, tiny_elements {{/str}}">
                <div class="elements-preview-head">
                    <span class="elements-bar-label">{{#str}} preview, tiny_elements {{/str}}</span>
                </div>
                <div class="elements-preview-body">
                    <div class="elements-preview-default" data-id="code-preview-default">
                        {{#str}} previewdefault, tiny_elements {{/str}}
                    </div>
                    {{#buttons}}
                        <div data-id="code-preview-{{id}}"
                             class="elements-component-code {{#css}}elements-component-custom-code{{/css}} elements-hidden"
                             role="presentation"
                             style="{{css}}">{{{htmlcode}}}</div>
                    {{/buttons}}
                </div>
                <div class="elements-preview-footer">
                    <div class="elements-preview-summary" data-region="preview-summary"></div>
                    <button type="button" class="btn btn-primary elements-insert-btn" data-region="insert" disabled>
                        {{#str}} insertintoeditor, tiny_elements {{/str}}
                    </button>
                </div>
            </aside>
            {{/preview}}

            {{^preview}}
            <div class="elements-preview-footer elements-footer-inline">
                <div class="elements-preview-summary" data-region="preview-summary"></div>
                <button type="button" class="btn btn-primary elements-insert-btn" data-region="insert" disabled>
                    {{#str}} insertintoeditor, tiny_elements {{/str}}
                </button>
            </div>
            {{/preview}}
        </div>
    {{/body}}
{{/ core/modal }}
